{
  "buildCommand": "pnpm --filter @workspace/ly-restaurant... build",
  "outputDirectory": "artifacts/ly-restaurant/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
